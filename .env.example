# ==================== 模型路径配置 ====================
# ASR 模型存放根目录
model_root_dir=/path/to/your/models

# ==================== ASR 模式配置 ====================
# 可选模式：
# - offline: 收完整音频后单次推理
# - streaming: 流式识别，实时返回 partial/final 结果
# - 2pass: 流式输出草稿，音频结束后离线精校

# FunASR 离线模式
# ASR_MODE=offline
# ASR_BACKEND=funasr_offline

# FunASR 流式模式
# ASR_MODE=streaming
# ASR_BACKEND=funasr_streaming

# FunASR 2-pass 模式（流式实时 + 离线精校）
ASR_MODE=2pass
ASR_FIRST_PASS_BACKEND=funasr_streaming
ASR_SECOND_PASS_BACKEND=funasr_offline

# ==================== ASR 服务地址配置 ====================
# FunASR HTTP 服务地址
ASR_SERVER_URL=http://localhost:7888/

# FunASR WebSocket 服务地址
ASR_WS_URL=ws://localhost:21590/ws/asr

# ==================== Qwen ASR API 配置 ====================
# OpenAI 格式的 ASR API 配置
ASR_API_KEY=your_asr_api_key
ASR_BASE_URL=http://localhost:8875/v1
ASR_MODEL=/path/to/Qwen3-ASR

# ==================== OpenAI API 配置 ====================
# 阿里云 DashScope API Key（用于 Qwen 模型）
DASHSCOPE_API_KEY=your_dashscope_api_key

# OpenAI API 配置（聊天功能）
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1